# PostgreSQL connection string for the future Neon database.
DATABASE_URL="postgresql://user:password@host:5432/chefos_recipes?sslmode=require"

# Secret used later to sign short-lived JWT access tokens.
JWT_SECRET="replace-with-a-long-random-access-token-secret"

# Secret used later to sign long-lived JWT refresh tokens.
JWT_REFRESH_SECRET="replace-with-a-different-long-random-refresh-token-secret"

# Public base URL for the web application.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
